# Helios environment configuration template.
# Copy to .env (gitignored) and fill in the keys you actually want to use.
# Leaving both LLM keys blank is fine — the reporting consumer falls back
# to the templated MockGenerator so the demo always runs end-to-end.

# -----------------------------------------------------------------------------
# Report generator
# -----------------------------------------------------------------------------
# 'gemini' (default), 'claude', or 'mock'.
# If the chosen provider's key is missing the consumer logs a warning and
# uses mock so the demo never silently fails.
REPORT_GENERATOR_MODE=gemini

# Google Gemini — free tier (1500 req/day on gemini-1.5-flash).
# Get a key in 30 seconds at https://aistudio.google.com — no credit card.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude — paid. Only used if REPORT_GENERATOR_MODE=claude.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Detection model
# -----------------------------------------------------------------------------
# Production threshold is derived from `scripts/evaluate.py` and loaded
# from models/evaluation/results.json at startup. Set this only if you
# want to override the eval-derived value for an experiment.
# ANOMALY_THRESHOLD=-0.5

# -----------------------------------------------------------------------------
# Database / Kafka — defaults match docker-compose; override for managed
# infra in Phase 6.
# -----------------------------------------------------------------------------
# DB_HOST=timescaledb
# DB_PASSWORD=postgres
# KAFKA_BROKERS=kafka:29092
