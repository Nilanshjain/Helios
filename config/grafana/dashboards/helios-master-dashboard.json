      },
      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('1 minute', time) AS time,\n  service AS metric,\n  COUNT(*) AS value\nFROM events\nWHERE $__timeFilter(time)\nGROUP BY 1, 2\nORDER BY 1",
