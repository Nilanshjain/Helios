    {
      "id": 9,
      "gridPos": {
        "w": 12,
        "h": 9,
        "x": 12,
        "y": 24
      },
      "type": "timeseries",
      "title": "Database Write Latency (avg)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "helios-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  time_bucket('1 minute', time) AS time,\n  AVG(EXTRACT(EPOCH FROM (ingested_at - time)) * 1000) AS value\nFROM events\nWHERE $__timeFilter(time) AND ingested_at IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "helios-timescaledb"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 10,
      "gridPos": {
        "w": 14,
        "h": 10,
        "x": 0,
        "y": 33
      },
      "type": "table",
      "title": "Events by Service (Last Hour)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "helios-timescaledb"
      },
      "targets": [
        {
          "rawSql": "SELECT\n  service AS \"Service\",\n  COUNT(*) AS \"Event Count\",\n  COUNT(CASE WHEN level IN ('ERROR', 'CRITICAL') THEN 1 END) AS \"Errors\",\n  ROUND(AVG(EXTRACT(EPOCH FROM (ingested_at - time)) * 1000), 2) AS \"Avg Latency (ms)\"\nFROM events\nWHERE time > NOW() - INTERVAL '1 hour' AND ingested_at IS NOT NULL\nGROUP BY service\nORDER BY COUNT(*) DESC",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "helios-timescaledb"
          }
        }
      ],
      "options": {
        "showHeader": true
      }
